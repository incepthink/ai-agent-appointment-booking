# Pause (ms) between sequential reply bubbles, e.g. body then trailing question.
# Keeps them in order; set to 0 to send back-to-back with no pause.
WHATSAPP_INTER_MESSAGE_DELAY_MS=600

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Dashboard (clinic owner login + REST API)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Keep this STABLE across restarts/deploys — changing it invalidates every saved
# login token, which surfaces in the dashboard as "Missing or malformed
# Authorization header" on all API calls until clinics log in again.
JWT_SECRET=change-me-to-a-long-random-string
# Secret for the admin-only clinic provisioning API (x-admin-key header)
ADMIN_API_KEY=change-me-to-a-long-random-string
# Comma-separated list of browser origins allowed to call the REST API (CORS).
# In production (EC2) include the deployed dashboard URL plus any extra origins,
# e.g. DASHBOARD_ORIGIN=https://dashboard.yourdomain.com,http://localhost:3001
DASHBOARD_ORIGIN=http://localhost:3001,https://ai-agent-appointment-booking.vercel.app/
#
# Production (EC2) notes:
#  - The dashboard bakes NEXT_PUBLIC_API_URL at BUILD time. Build it with
#    NEXT_PUBLIC_API_URL=https://<api-host>/api (not localhost).
#  - If nginx fronts the API, forward the Authorization header (default) and
#    disable proxy buffering for the SSE route (/api/appointments/stream):
#      proxy_buffering off; proxy_cache off; proxy_set_header Connection '';

# Clinic
CLINIC_NAME=Acme Clinic
CLINIC_TZ=Asia/Kolkata
CLINIC_OPEN=09:00
CLINIC_CLOSE=18:00
CLINIC_DAYS=Mon,Tue,Wed,Thu,Fri,Sat
SLOT_MINUTES=30
